{
  "slug": "moment-benchmark",
  "description": "Deterministic moment-search cases over synthetic-project.json. Scene cases pass queryVector directly into searchScenes (no CLIP spawn). Text cases use grepMomentTextMatches.",
  "cases": [
    {
      "id": "text-design-feedback-kept",
      "kind": "text",
      "query": "design feedback",
      "expectedMatches": [
        {
          "fromSec": 12,
          "toSec": 13.2,
          "cut": false,
          "text": "design feedback"
        }
      ]
    },
    {
      "id": "text-canvas-design-kept",
      "kind": "text",
      "query": "canvas design",
      "expectedMatches": [
        {
          "fromSec": 24,
          "toSec": 25,
          "cut": false,
          "text": "canvas design"
        }
      ]
    },
    {
      "id": "text-you-know-cut",
      "kind": "text",
      "query": "you know",
      "expectedMatches": [
        {
          "fromSec": 30,
          "toSec": 30.6,
          "cut": true,
          "text": "you know"
        }
      ]
    },
    {
      "id": "text-no-match",
