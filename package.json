{
  "name": "openklip",
  "version": "0.42.0.3",
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@huggingface/transformers": "4.2.0",
    "@json-render/core": "0.19.0",
    "@json-render/react": "0.19.0",
    "@livekit/components-react": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@paper-design/shaders": "^0.0.77",
    "@pierre/diffs": "^1.2.12",
    "@shadcn/react": "^0.2.0",
    "@tabler/icons-react": "^3.44.0",
    "ai": "^7.0.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cuelume": "^0.1.0",
    "culori": "^4.0.2",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "glimm": "0.1.4",
    "livekit-client": "^2.0.0",
    "lucide-react": "^1.23.0",
    "maplibre-gl": "^5.24.0",
    "motion": "^12.42.2",
    "nanoid": "^5.1.16",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "puppeteer-core": "^25.2.1",
    "react": "19",
    "react-dom": "19",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@types/bun": "^1.2.0",
    "@types/culori": "^4.0.1",
    "@types/geojson": "^7946.0.16",
    "@types/react": "19",
    "@types/react-dom": "19",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "ultracite": "7.8.3"
  },
  "bin": {
    "openklip": "./src/cli.ts",
    "openklip-mcp": "./src/mcp-server.ts"
  },
  "description": "Agent-native video editor: CLI edit loop, browser review, plain files on disk.",
  "homepage": "https://openklip.com",
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=24"
  },
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "private": true,
  "scripts": {
    "dev": "bun --bun next dev -p 4399",
    "build": "bun --bun next build",
    "start": "bun --bun next start -p 4399",
    "serve": "bun run src/cli.ts serve",
    "mcp": "bun run src/mcp-server.ts",
    "ingest": "bun run src/cli.ts ingest",
    "export": "bun run src/cli.ts export",
    "agent-demo": "bun run scripts/agent-demo.ts",
    "agent-smoke-audit": "bun run scripts/agent-smoke-audit.ts",
    "agent-make-short": "bun run scripts/agent-make-short.ts",
    "agent-make-highlights": "bun run scripts/agent-make-highlights.ts",
    "generate-multicam-fixture": "bun run scripts/generate-multicam-fixture.ts",
    "multicam-acceptance": "bun test --isolate tests/multicam-acceptance.test.ts",
    "cam-devex-smoke": "bun run scripts/cam-devex-smoke.ts",
    "demo-gif": "bash scripts/record-demo-gif.sh",
    "test": "bun test --isolate",
    "test:integration": "OPENKLIP_INTEGRATION=1 bun test tests/transcript-diff-browser.test.ts tests/json-graphic-browser.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "ci": "bun run check && bun run typecheck && bun run test && bun run build"
  },
  "trustedDependencies": [
    "ffmpeg-static",
    "onnxruntime-node",
    "protobufjs",
    "sharp"
  ],
  "type": "module"
}
