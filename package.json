{
  "name": "openklip",
  "version": "0.8.8.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=24"
  },
  "description": "Agent-native video editor: CLI edit loop, browser review, plain files on disk.",
  "bin": {
    "openklip": "./src/cli.ts",
    "openklip-mcp": "./src/mcp-server.ts"
  },
  "scripts": {
    "dev": "bun --bun next dev -p 4399",
    "build": "bun --bun next build",
    "start": "bun --bun next start -p 4399",
    "serve": "bun run src/cli.ts serve",
    "mcp": "bun run src/mcp-server.ts",
    "ingest": "bun run src/cli.ts ingest",
    "export": "bun run src/cli.ts export",
    "agent-demo": "bun run scripts/agent-demo.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "ci": "bun run check && bun run typecheck && bun test && bun run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@huggingface/transformers": "4.2.0",
    "@livekit/components-react": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@phosphor-icons/react": "^2.1.10",
    "ai": "^7.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "culori": "^4.0.2",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "glimm": "0.1.4",
    "livekit-client": "^2.0.0",
    "motion": "^12.42.0",
    "nanoid": "^5.1.16",
    "next": "^16.2.9",
    "radix-ui": "^1.6.0",
    "react": "19",
    "react-dom": "19",
    "shadcn": "4.11.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "use-stick-to-bottom": "^1.1.6",
    "vaul": "^1.1.2",
    "zod": "4.4.3"
  },
  "optionalDependencies": {
    "@hyperframes/producer": "^0.7.17"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/bun": "^1.2.0",
    "@types/culori": "^4.0.1",
    "@types/react": "19",
    "@types/react-dom": "19",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "ultracite": "7.8.3"
  },
  "trustedDependencies": [
    "ffmpeg-static",
    "onnxruntime-node",
    "protobufjs",
    "sharp"
  ]
}
