{
  "name": "openklip",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "description": "Agent-native, transcript-driven video editor. Edit by editing text.",
  "bin": {
    "openklip": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun --bun next dev -p 4399",
    "build": "bun --bun next build",
    "start": "bun --bun next start -p 4399",
    "ingest": "bun run src/cli.ts ingest",
    "export": "bun run src/cli.ts export",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@huggingface/transformers": "4.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "radix-ui": "^1.6.0",
    "react": "19",
    "react-dom": "19",
    "shadcn": "4.11.1",
    "tailwind-merge": "^3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/bun": "^1.2.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3"
  },
  "trustedDependencies": [
    "ffmpeg-static",
    "onnxruntime-node",
    "protobufjs",
    "sharp"
  ]
}
